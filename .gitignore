/rdq
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Frontend
frontend/node_modules/
frontend/dist/

# Embedded frontend build (copied from frontend/dist).
# Keep .gitkeep so //go:embed all:dist has at least one file
# when the module is fetched via `go install` (no local frontend build).
internal/server/dist/*
!internal/server/dist/.gitkeep
